# ============================================
# LifeOS Backend - Variables de Entorno
# Copia este archivo como .env
# ============================================

# --- Base de Datos ---
DATABASE_URL="postgresql://lifeos:lifeos_dev_2026@localhost:5432/lifeos?schema=public"

# --- JWT ---
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-change-in-production-min-32-chars
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# --- App ---
PORT=3000
NODE_ENV=development

# --- CORS ---
CORS_ORIGIN=http://localhost:5173

# --- Email verification ---
EMAIL_VERIFICATION_CODE_LENGTH=6
EMAIL_VERIFICATION_EXPIRY_MINUTES=15
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_ATTEMPTS=5

# Delivery transport: smtp | log
# In development, log is the safest default.
EMAIL_VERIFICATION_TRANSPORT=log

# SMTP (required when EMAIL_VERIFICATION_TRANSPORT=smtp)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@lifeos.local
# Optional: true for TLS, false for plain. If omitted, inferred by port (465 => true).
SMTP_SECURE=false
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_SEND_TIMEOUT_MS=10000
